# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Your deployed Clarity contract address on Stacks mainnet
# Get this after deploying contracts/deadlock.clar via Hiro Explorer
NEXT_PUBLIC_CONTRACT_ADDRESS=SP_YOUR_ADDRESS_HERE

# Contract name (must match what you used when deploying)
NEXT_PUBLIC_CONTRACT_NAME=deadlock

# Network: mainnet or testnet
NEXT_PUBLIC_NETWORK=mainnet
