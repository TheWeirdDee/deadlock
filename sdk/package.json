{
  "name": "@deadlock/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for interacting with the DEADLOCK on-chain accountability protocol",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "keywords": ["stacks", "clarity", "deadlock", "accountability", "web3"],
  "license": "MIT",
  "peerDependencies": {
    "@stacks/network": ">=6.0.0",
    "@stacks/transactions": ">=6.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
