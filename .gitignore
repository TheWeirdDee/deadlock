# =============================================
# DEADLOCK — .gitignore
# =============================================

# --- Dependencies ---
node_modules/
.pnp
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Next.js build output ---
.next/
out/
build/

# --- Environment variables — NEVER commit these ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Matches all .env.* variants (e.g. .env.staging)
.env*

# --- Vercel deployment metadata ---
.vercel

# --- TypeScript compilation cache ---
*.tsbuildinfo
next-env.d.ts

# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- OS generated files ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Editor / IDE config ---
.vscode/
.idea/
*.swp
*.swo
*.suo
*.user

# --- Testing coverage reports ---
coverage/
.nyc_output

# --- SSL / Secrets ---
*.pem
*.key
*.cert

# --- Private automation scripts ---
# These scripts contain wallet automation logic and must never be committed.
private/
scripts/
state/
